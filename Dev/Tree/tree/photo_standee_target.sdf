<?xml version="1.0"?>
<sdf version="1.5">
  <model name="tree">
    <static>true</static>
    <link name="tree">
      <!-- Pose of the link relative to the model:
           x y z roll pitch yaw -->
      <pose>0 0 0.915 0 0 0</pose>

      <!-- Collision is REQUIRED if you want front_rangefinder / lidar / ray sensors
           to measure the target distance. -->
      <collision name="tree_collision">
        <geometry>
          <box>
            <!-- thickness width height -->
            <size>0.02 0.57 1.83</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <collide_without_contact>true</collide_without_contact>
          </contact>
        </surface>
      </collision>

      <!-- Visual textured face -->
      <visual name="tree_visual">
        <cast_shadows>false</cast_shadows>
        <geometry>
          <box>
            <size>0.02 0.57 1.83</size>
          </box>
        </geometry>
        <material>
          <script>
            <uri>model://tree/materials/scripts</uri>
            <uri>model://tree/materials/textures</uri>
            <name>tree</name>
          </script>
        </material>
      </visual>
    </link>
  </model>
</sdf>
